# ---- Backend selection ----
# fake   = deterministic offline simulator (default, no keys)
# ollama = local models, key-free
# openai = OpenAI-compatible endpoint (real cost numbers)
GRAPHTHRIFT_BACKEND=fake

# ---- Ollama (local) ----
GRAPHTHRIFT_OLLAMA_BASE_URL=http://localhost:11434
GRAPHTHRIFT_OLLAMA_MODEL=qwen2.5:3b
GRAPHTHRIFT_OLLAMA_SMALL_MODEL=qwen2.5:0.5b
GRAPHTHRIFT_OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- OpenAI-compatible ----
GRAPHTHRIFT_OPENAI_BASE_URL=https://api.openai.com/v1
GRAPHTHRIFT_OPENAI_API_KEY=
GRAPHTHRIFT_OPENAI_MODEL=gpt-5.5
GRAPHTHRIFT_OPENAI_SMALL_MODEL=gpt-4.1-nano
GRAPHTHRIFT_OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Storage ----
# sqlite (default) or postgresql+psycopg://user:pass@host:5432/db
GRAPHTHRIFT_DATABASE_URL=sqlite:///./graphthrift_data/graphthrift.sqlite3

# ---- API auth (optional) ----
GRAPHTHRIFT_AUTH_ENABLED=false
GRAPHTHRIFT_API_KEY=

# ---- Optimizer defaults ----
GRAPHTHRIFT_CACHE_ENABLED=true
GRAPHTHRIFT_EMBEDDING_CACHE_ENABLED=true
GRAPHTHRIFT_ROUTER_ENABLED=true
GRAPHTHRIFT_DEDUP_PREFILTER_ENABLED=true
GRAPHTHRIFT_EDGE_BATCHER_ENABLED=true
GRAPHTHRIFT_COMPRESSOR_ENABLED=true

# ---- Eval gate ----
GRAPHTHRIFT_QUALITY_EPSILON=0.02

# ---- Concurrency / logging ----
GRAPHTHRIFT_MAX_CONCURRENCY=20
GRAPHTHRIFT_LOG_LEVEL=INFO
GRAPHTHRIFT_LOG_JSON=false
